VUE_APP_TITLE=Private RAG
VUE_APP_FAVICON=favicon.ico
VUE_APP_BACKGROUND_VIDEO=

# URL to the backend — use the host/IP where the backend is reachable from your browser
# Docker compose example: http://localhost:3000
# Remote server example: http://YOUR_SERVER_IP:3000
VUE_APP_API_HOST=http://localhost:3000

# Bot ID from the database (create a bot via the admin UI after first run, then paste its UUID here)
VUE_APP_API_BOT_ID=
