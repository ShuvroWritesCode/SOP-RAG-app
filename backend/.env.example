# PostgreSQL — when running via docker-compose, set DB_HOST=db
# When running manually on the same machine, set DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=postgres
DB_DATABASE=ai-admin
DB_HOST=localhost
DB_PORT=5432
DB_DIALECT=postgres
# Keep false in production; use true only for controlled schema adjustments
DB_SYNC_ALTER=false

JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRY=3600s
# In production keep disabled unless you explicitly need bootstrap credentials
SEED_DEFAULT_ADMIN=false

PUBLIC_FILES_STORAGE=storage/
CONVERSATIONS_FOLDER_PATH=conversations/
CONVERSATIONS_METADATA_FOLDER_PATH=conversations-metadata/

# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

PORT=3000
