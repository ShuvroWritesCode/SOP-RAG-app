# PostgreSQL — when running via docker-compose, set DB_HOST=db
# When running manually on the same machine, set DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=postgres
DB_DATABASE=ai-admin
DB_HOST=localhost
DB_PORT=5432
DB_DIALECT=postgres
# Keep false in production; use true only for controlled schema adjustments
DB_SYNC_ALTER=false

JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRY=3600s
# In production keep disabled unless you explicitly need bootstrap credentials
SEED_DEFAULT_ADMIN=false

PUBLIC_FILES_STORAGE=storage/
CONVERSATIONS_FOLDER_PATH=conversations/
CONVERSATIONS_METADATA_FOLDER_PATH=conversations-metadata/

# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Comma-separated list of extra allowed CORS origins.
# Defaults already include:
# - http://localhost:8080
# - http://localhost:3000
# - http://127.0.0.1:8080
# - http://127.0.0.1:3000
# - http://sopai.kaizenapps.com
# - https://sopai.kaizenapps.com
# Add your server public IP origin if needed, e.g. http://203.0.113.10:8080
CORS_ORIGINS=
# Allow CORS from private IPv4 addresses (e.g. 192.168.x.x). Set false to tighten policy.
CORS_ALLOW_PRIVATE_IP=true

PORT=3000
